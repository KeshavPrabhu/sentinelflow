# sentinelflow/.env.example

# --- Database Credentials ---
DB_USER=pipelineops
DB_PASSWORD=pipelinepass
DB_NAME=pipelineops

# --- Application Settings ---
# Used for the frontend display and local image tagging
APP_VERSION=1.0.0
IMAGE_TAG=dev-latest
SECRET_KEY=yoursecretkeyhere

# --- External Integration ---
# GitLab Personal Access Token for API data fetching
GITLAB_TOKEN=your_gitlab_token_here
GITLAB_PROJECT_ID=your_project_id

# --- Infrastructure URLs ---
# Prometheus and Alertmanager (for the Dashboard feeds)
PROMETHEUS_URL=http://localhost:9090
ALERTMANAGER_URL=http://localhost:9093

# --- Script Configuration ---
# Health URL for system_health_check.sh
APP_HEALTH_URL=http://localhost:5000/health